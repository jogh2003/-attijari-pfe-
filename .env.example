# ============================================================
# .env.example — PFE Attijari bank — Sujet 21
# Copier ce fichier en .env et remplir les valeurs
# IMPORTANT : Ne jamais committer le fichier .env sur Git !
# ============================================================

# ── Application ──────────────────────────────────────────────
APP_NAME="Systeme IA Attijari bank"
APP_VERSION="1.0.0"
DEBUG=True
SECRET_KEY=votre_cle_secrete_tres_longue_et_aleatoire_ici

# ── Base de données PostgreSQL ───────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=attijari_pfe
DB_USER=postgres
DB_PASSWORD=postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/attijari_pfe

# ── Sécurité JWT ─────────────────────────────────────────────
JWT_SECRET_KEY=votre_jwt_secret_tres_long_et_aleatoire
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480

# ── Chiffrement AES-256 ──────────────────────────────────────
AES_KEY=votre_cle_aes_32_caracteres_exactement!!

# ── Elasticsearch ────────────────────────────────────────────
ES_HOST=localhost
ES_PORT=9200
ES_INDEX_RECLAMATIONS=reclamations

# ── Redis ────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# ── MLflow ───────────────────────────────────────────────────
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=attijari_lstm

# ── Modèle prédictif ─────────────────────────────────────────
SEUIL_RISQUE=0.75
FENETRE_LSTM=30
RETRAIN_INTERVAL_DAYS=7

# ── Données ──────────────────────────────────────────────────
CSV_PATH=data/raw/reclamations.csv
MODEL_PATH=models/lstm_model.h5

# ── Notifications ────────────────────────────────────────────
SMTP_HOST=smtp.attijaribank.tn
SMTP_PORT=587
SMTP_USER=noreply@attijaribank.tn
SMTP_PASSWORD=votre_mot_de_passe_smtp
SLACK_WEBHOOK_URL=https://hooks.slack.com/votre_webhook

# ── Backup ───────────────────────────────────────────────────
BACKUP_PATH=backups/
BACKUP_RETENTION_DAYS=30
